# ─────────────────────────────────────────────────────────────
# Streamlit secrets 예시 (Streamlit Cloud 배포용)
#
# 사용법:
#   이 파일을 복사해서 ".streamlit/secrets.toml" 로 저장한 뒤 값을 채우세요.
#   .streamlit/secrets.toml 은 .gitignore에 포함되어 커밋되지 않습니다.
#
# 로컬 개발:
#   .env 파일 방식을 추천합니다 (.env.example 참고).
#   secrets.toml 은 Streamlit Cloud 배포 환경에서 주로 사용됩니다.
# ─────────────────────────────────────────────────────────────


# ── 앱 비밀번호 (비워두면 잠금 화면 없음) ──
app_password = ""

# ── Google Drive 관심종목 업로드 (선택) ──
# 설정 가이드: docs/google-drive-watchlist-setup.md
google_drive_upload_url = ""
google_drive_upload_token = ""
