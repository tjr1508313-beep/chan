# ─────────────────────────────────────────────────────────────
# 주식 스크리닝 앱 환경변수 예시
#
# 사용법:
#   이 파일을 복사해서 ".env" 파일로 저장한 뒤 값을 채우세요.
#   cp .env.example .env
#
#   .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
#   앱 실행 시 자동으로 읽혀서 환경변수로 등록됩니다.
# ─────────────────────────────────────────────────────────────


# ── LS증권 OpenAPI 키 (한국 관리/위험종목 필터 기능에 필요) ──
#
# 발급 위치: https://openapi.ls-sec.co.kr → 앱 등록 → App Key / App Secret
# 조회전용 키로 충분합니다.
#
LS_APP_KEY=여기에_앱키_입력
LS_APP_SECRET=여기에_앱시크릿_입력


# ── 앱 비밀번호 (배포 환경에서 접근 제한 시 사용, 로컬은 비워도 됨) ──
#
# 설정하면 앱 접속 시 비밀번호 입력창이 표시됩니다.
# 비워두면 잠금 화면 없이 바로 진입합니다.
#
SCREENING_PASSWORD=


# ── 아래 항목은 특별한 경우에만 설정 ──

# 원격 캐시 레포 (기본값: tjr1508313-beep/chan, 포크 시 변경)
# SCREENING_CACHE_REPO=owner/repo

# 원격 캐시 자동 동기화 끄기 (1로 설정하면 비활성)
# SCREENING_SKIP_REMOTE_SYNC=1
