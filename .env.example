# ─────────────────────────────────────────────────────────────
# 주식 스크리닝 앱 환경변수 예시
#
# 사용법:
#   이 파일을 복사해서 ".env" 파일로 저장한 뒤 값을 채우세요.
#   cp .env.example .env
#
#   .env 파일은 .gitignore에 포함되어 있어 커밋되지 않습니다.
#   앱 실행 시 자동으로 읽혀서 환경변수로 등록됩니다.
# ─────────────────────────────────────────────────────────────


# ── 앱 비밀번호 (배포 환경에서 접근 제한 시 사용, 로컬은 비워도 됨) ──
#
# 설정하면 앱 접속 시 비밀번호 입력창이 표시됩니다.
# 비워두면 잠금 화면 없이 바로 진입합니다.
#
SCREENING_PASSWORD=

# ── Google Drive 관심종목 업로드 (선택) ──
# GOOGLE_DRIVE_UPLOAD_URL=https://script.google.com/macros/s/.../exec
# GOOGLE_DRIVE_UPLOAD_TOKEN=충분히_긴_임의_문자열


# ── 아래 항목은 특별한 경우에만 설정 ──

# 원격 캐시 레포 (기본값: tjr1508313-beep/chan, 포크 시 변경)
# SCREENING_CACHE_REPO=owner/repo

# 원격 캐시 자동 동기화 끄기 (1로 설정하면 비활성)
# SCREENING_SKIP_REMOTE_SYNC=1

# LS Securities OpenAPI
#  - KR 위험종목 필터(관리종목/매매정지/정리매매, screening/kr_risk.py)
#  - KR 섹터 매핑 보강(screening/ls_sector.py)
#  미설정 시 위 두 기능만 조용히 skip (앱은 정상 동작)
# LS_APP_KEY=
# LS_APP_SECRET=

# Kiwoom REST API (optional, reserved for future data enrichment)
# KIWOOM_APP_KEY=
# KIWOOM_APP_SECRET=
